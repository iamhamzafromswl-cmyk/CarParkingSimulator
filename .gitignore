# This .gitignore file is based on the Unity official .gitignore template.
# It helps to keep your repository clean by ignoring files generated by Unity and your IDE.

# =============== #
# Unity generated #
# =============== #

# Memory Snapshot files
*.snap

# Files and folders managed by Unity
.vs/
.idea/
.vscode/

# Build results
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/

# Crash reports
/[Cc]rashReports/

# Asset meta data
*.meta

# Generated assets
*.asset

# Packages
/[Pp]ackages/

# Local Unity settings
/[Pp]rojectSettings/

# Visual Studio cache
.vs/

# Rider cache
.idea/

# Visual Studio Code cache
.vscode/

# Gradle cache
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity Editor generated files
*.unitypackage

# OS generated files
.DS_Store
.Trashes
Thumbs.db

# =============== #
# Custom additions #
# =============== #

# Any additional files or folders you want to ignore
